# EU Lens Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# OpenAI API (optional - falls back to local mock data)
OPENAI_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Cache
CACHE_TTL=300

# Frontend
VITE_API_URL=http://localhost:3001/api/v1
